{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ProgramBlueprint": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SessionBlueprint"
          }
        },
        "lastEdited": {
          "$ref": "#/definitions/LocalDate"
        }
      },
      "required": [
        "name",
        "sessions",
        "lastEdited"
      ]
    },
    "SessionBlueprint": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "exercises": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExerciseBlueprint"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "exercises",
        "notes"
      ]
    },
    "ExerciseBlueprint": {
      "anyOf": [
        {
          "$ref": "#/definitions/WeightedExerciseBlueprint"
        },
        {
          "$ref": "#/definitions/CardioExerciseBlueprint"
        }
      ]
    },
    "WeightedExerciseBlueprint": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "WeightedExerciseBlueprint"
        },
        "name": {
          "type": "string"
        },
        "sets": {
          "type": "number"
        },
        "repsPerSet": {
          "type": "number"
        },
        "weightIncreaseOnSuccess": {
          "$ref": "#/definitions/BigNumber"
        },
        "restBetweenSets": {
          "$ref": "#/definitions/Rest"
        },
        "supersetWithNext": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "sets",
        "repsPerSet",
        "weightIncreaseOnSuccess",
        "restBetweenSets",
        "supersetWithNext",
        "notes",
        "link"
      ]
    },
    "BigNumber": {
      "type": "string",
      "examples": [
        "1.23"
      ],
      "format": "number"
    },
    "Rest": {
      "type": "object",
      "properties": {
        "minRest": {
          "$ref": "#/definitions/Duration"
        },
        "maxRest": {
          "$ref": "#/definitions/Duration"
        },
        "failureRest": {
          "$ref": "#/definitions/Duration"
        }
      },
      "required": [
        "minRest",
        "maxRest",
        "failureRest"
      ]
    },
    "Duration": {
      "type": "string",
      "format": "duration"
    },
    "CardioExerciseBlueprint": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "CardioExerciseBlueprint"
        },
        "name": {
          "type": "string"
        },
        "sets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CardioExerciseSetBlueprint"
          }
        },
        "notes": {
          "type": "string"
        },
        "link": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "sets",
        "notes",
        "link"
      ]
    },
    "CardioExerciseSetBlueprint": {
      "type": "object",
      "properties": {
        "target": {
          "$ref": "#/definitions/CardioTarget"
        },
        "trackDuration": {
          "type": "boolean"
        },
        "trackDistance": {
          "type": "boolean"
        },
        "trackResistance": {
          "type": "boolean"
        },
        "trackIncline": {
          "type": "boolean"
        },
        "trackWeight": {
          "type": "boolean"
        },
        "trackSteps": {
          "type": "boolean"
        }
      },
      "required": [
        "target",
        "trackDuration",
        "trackDistance",
        "trackResistance",
        "trackIncline",
        "trackWeight",
        "trackSteps"
      ]
    },
    "CardioTarget": {
      "anyOf": [
        {
          "$ref": "#/definitions/TimeCardioTarget"
        },
        {
          "$ref": "#/definitions/DistanceCardioTarget"
        }
      ]
    },
    "TimeCardioTarget": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "time"
        },
        "value": {
          "$ref": "#/definitions/Duration"
        }
      },
      "required": [
        "type",
        "value"
      ]
    },
    "DistanceCardioTarget": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "distance"
        },
        "value": {
          "$ref": "#/definitions/Distance"
        }
      },
      "required": [
        "type",
        "value"
      ]
    },
    "Distance": {
      "type": "object",
      "properties": {
        "value": {
          "$ref": "#/definitions/BigNumber"
        },
        "unit": {
          "$ref": "#/definitions/DistanceUnit"
        }
      },
      "required": [
        "value",
        "unit"
      ]
    },
    "DistanceUnit": {
      "type": "string",
      "enum": [
        "metre",
        "yard",
        "mile",
        "kilometre"
      ]
    },
    "LocalDate": {
      "type": "string",
      "format": "date"
    },
    "Session": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "blueprint": {
          "$ref": "#/definitions/SessionBlueprint"
        },
        "recordedExercises": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RecordedExercise"
          }
        },
        "date": {
          "$ref": "#/definitions/LocalDate"
        },
        "bodyweight": {
          "$ref": "#/definitions/Weight"
        }
      },
      "required": [
        "id",
        "blueprint",
        "recordedExercises",
        "date"
      ]
    },
    "RecordedExercise": {
      "anyOf": [
        {
          "$ref": "#/definitions/RecordedCardioExercise"
        },
        {
          "$ref": "#/definitions/RecordedWeightedExercise"
        }
      ]
    },
    "RecordedCardioExercise": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "RecordedCardioExercise"
        },
        "blueprint": {
          "$ref": "#/definitions/CardioExerciseBlueprint"
        },
        "sets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RecordedCardioExerciseSet"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "blueprint",
        "sets"
      ]
    },
    "RecordedCardioExerciseSet": {
      "type": "object",
      "properties": {
        "blueprint": {
          "$ref": "#/definitions/CardioExerciseSetBlueprint"
        },
        "completionDateTime": {
          "$ref": "#/definitions/OffsetDateTime"
        },
        "duration": {
          "$ref": "#/definitions/Duration"
        },
        "distance": {
          "$ref": "#/definitions/Distance"
        },
        "resistance": {
          "$ref": "#/definitions/BigNumber"
        },
        "incline": {
          "$ref": "#/definitions/BigNumber"
        },
        "weight": {
          "$ref": "#/definitions/Weight"
        },
        "steps": {
          "type": "number"
        }
      },
      "required": [
        "blueprint"
      ]
    },
    "OffsetDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "Weight": {
      "type": "object",
      "properties": {
        "unit": {
          "$ref": "#/definitions/WeightUnit"
        },
        "value": {
          "$ref": "#/definitions/BigNumber"
        }
      },
      "required": [
        "unit",
        "value"
      ]
    },
    "WeightUnit": {
      "type": "string",
      "enum": [
        "kilograms",
        "pounds",
        "nil"
      ]
    },
    "RecordedWeightedExercise": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "RecordedWeightedExercise"
        },
        "blueprint": {
          "$ref": "#/definitions/WeightedExerciseBlueprint"
        },
        "potentialSets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PotentialSet"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "blueprint",
        "potentialSets"
      ]
    },
    "PotentialSet": {
      "type": "object",
      "properties": {
        "set": {
          "$ref": "#/definitions/RecordedSet"
        },
        "weight": {
          "$ref": "#/definitions/Weight"
        }
      },
      "required": [
        "weight"
      ]
    },
    "RecordedSet": {
      "type": "object",
      "properties": {
        "repsCompleted": {
          "type": "number"
        },
        "completionDateTime": {
          "$ref": "#/definitions/OffsetDateTime"
        }
      },
      "required": [
        "repsCompleted",
        "completionDateTime"
      ]
    },
    "ExerciseDescriptor": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "force": {
          "type": [
            "string",
            "null"
          ]
        },
        "level": {
          "type": "string"
        },
        "mechanic": {
          "type": [
            "string",
            "null"
          ]
        },
        "equipment": {
          "type": [
            "string",
            "null"
          ]
        },
        "muscles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instructions": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "force",
        "level",
        "mechanic",
        "equipment",
        "muscles",
        "instructions",
        "category"
      ]
    }
  }
}