  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "WorkoutUpdatedEvent"
    },
    "workout": {
      "$ref": "./Session.json"
    },
    "restTimerInfo": {
      "$ref": "./RestTimerInfo.json"
    },
    "cardioTimerInfo": {
      "$ref": "./CardioTimerInfo.json"
    },
    "currentExerciseDetails": {
      "$ref": "./CurrentExerciseDetails.json"
    },
