{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "IncreaseLowestSetProgressiveOverload"
    },
    "amount": {
      "$ref": "./BigNumber.json"
    },
    "increaseStrategy": {
      "type": "string",
      "enum": [
        "first",
        "middle",
        "last",
        "all"
      ]
    }
  },
  "required": [
    "type",
    "amount",
    "increaseStrategy"
  ]
}