{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "WeightedExerciseBlueprint"
    },
    "name": {
      "type": "string"
    },
    "sets": {
      "type": "integer"
    },
    "repsPerSet": {
      "type": "integer"
    },
    "restBetweenSets": {
      "$ref": "./Rest.json"
    },
    "supersetWithNext": {
      "type": "boolean",
      "description": "When true, this exercise is performed back-to-back with the following one (a superset), with no rest in between."
    },
    "notes": {
      "type": "string"
    },
    "link": {
      "type": "string",
      "description": "A url to some explanation of how to do this. We should not fill this unless the user has explicitly given us a link to fill"
    },
    "progressiveOverload": {
      "$ref": "./ProgressiveOverload.json"
    }
  },
  "required": [
    "type",
    "name",
    "sets",
    "repsPerSet",
    "restBetweenSets",
    "supersetWithNext",
    "notes",
    "link",
    "progressiveOverload"
  ]
}