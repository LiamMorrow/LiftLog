{
  "name": "lambda-backup",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "package": "npm run build && rm -f ../terraform/lambda.zip && cd dist && find . -type f -exec touch -t 198001010000 {} + && find . -type f -print | LC_ALL=C sort | zip -X -q ../../terraform/lambda.zip -@",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.13.2",
    "ts-loader": "^9.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
