{
  "expo": {
    "name": "LiftLog",
    "slug": "liftlog",
    "version": "1.0.0",
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "icon": "./assets/icon.png",
    "backgroundColor": "#fcfdf6",
    "primaryColor": "#046F03",
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-health-connect",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": false,
          "NSHealthUpdateUsageDescription": "LiftLog would like to share your workout and/or body weight with Apple Health.",
          "background": false
        }
      ],
      "expo-localization",
      "expo-sharing",
      "./plugins/override-health-connect-min-version.js",
      "./plugins/android-signing.js",
      "./plugins/android-gradle-properties.js",
      "./plugins/android-react-native-feature-flags.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification.png"
        }
      ],
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fcfdf6",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "scheme": "liftlog",
    "android": {
      "versionCode": "project.hasProperty('BUILD_NUMBER') ? project.property('BUILD_NUMBER').toInteger() : 1",
      "version": "${project.hasProperty('DISPLAY_VERSION') ? project.property('DISPLAY_VERSION') : \"1.0.0\"}",
      "package": "com.limajuice.liftlog",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.health.WRITE_WEIGHT",
        "android.permission.health.WRITE_EXERCISE",
        "android.permission.health.WRITE_EXERCISE_ROUTE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.liftlog.online"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#dfedda",
        "foregroundImage": "./assets/icon_foreground.png",
        "monochromeImage": "./assets/icon_monochrome.png"
      }
    },
    "ios": {
      "bundleIdentifier": "com.limajuice.liftlog",
      "associatedDomains": ["applinks:app.liftlog.online"],
      "supportsTablet": true,
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true,
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "ar",
          "cs",
          "de",
          "en",
          "es",
          "fi",
          "fr",
          "hu",
          "it",
          "ko",
          "nl",
          "pl",
          "pt",
          "ru",
          "sr",
          "sv",
          "tr",
          "uk",
          "zh-hans"
        ]
      },
      "appleTeamId": "",
      "version": "$(APP_DISPLAY_VERSION)",
      "buildNumber": "$(APP_VERSION)"
    }
  }
}
