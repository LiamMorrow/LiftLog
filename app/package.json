{
  "name": "liftlog-react",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "build:android:release": "./android/gradlew assembleRelease",
    "build:web": "expo export -p web --source-maps",
    "android": "expo run:android  --variant debugOptimized",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "dev": "expo start --dev-client",
    "web": "expo start --web",
    "lint": "eslint .",
    "postinstall": "npm run patch-package",
    "protojs": "pbjs -p ../ -t static-module $(find ../proto -name '*.proto') -o ./gen/proto.js -w es6 --es6 --force-long",
    "protots": "pbts -o ./gen/proto.d.ts ./gen/proto.js",
    "proto": "npm run protojs && npm run protots",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
